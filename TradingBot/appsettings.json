{
  //"_comment": "Primary application settings. Values here are loaded first, then overridden by platformSettings.json and aiSettings.json when same keys exist.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CacheKeys": [
    "TimeStampOffset",
    "{symbol}_ExchangeInformation"
  ],
  "RedisSettings": {
    "Host": "localhost:6379",
    "Password": ""
  },
  "Binance": {
    "Http": {
      "TimeoutSeconds": 15,
      "RetryCount": 3,
      "RetryBaseDelayMilliseconds": 300
    }
  },
  "ConnectionStrings": {
    "MainStorage": "Host=localhost;Port=5432;Database=projecttemplate;Username=postgres;Password="
  },

  "DecisionEngine": {
    // TESTNET OBSERVATION MODE
    // Lowered gates so the bot can actually generate trades and you can observe execution/order sync/fill sync/position monitoring.
    "Symbol": "BNBUSDT",
    "Symbols": [ "BNBUSDT" ],

    // BNB price around 631 means 0.01 BNB is around 6+ USDT, so it passes your MinOrderQuote = 5.
    "Quantity": 0.01,

    "IntervalSeconds": 15,

    "MinConfidence": 0.70,
    "MinConfidenceThreshold": 0.70,
    "MinExecutionConfidence": 0.70,
    "MinimumSignalConfidence": 0.25,

    "UseAIValidator": false,

    "TradeCooldownSeconds": 30,
    "IdempotencyWindowSeconds": 30,

    "MovingAverageCrossoverStrategy": {
      "ShortPeriod": 5,
      "LongPeriod": 12,

      "TrendStrengthThreshold": 0.0001,
      "MomentumFlatteningThreshold": 0.00001,

      "CooldownSeconds": 30,

      "MinimumTrendConfidenceScore": 25,
      "MinimumMarketConditionScore": 25,

      "AllowShortSelling": true,
      "RequireCrossoverForEntry": false,

      "ExitOnWeakTrendConfidence": true,
      "MinimumExitTrendConfidenceScore": 20
    },
    "Strategies": {
      "MovingAverageCrossover": {
        "MinConfidence": 0.70
      }
    },

    "MarketCondition": {
      "AtrPeriod": 7,
      "VolatilityWindow": 7,
      "RollingVolatilityWindow": 20,

      "LowVolatilityMultiplier": 0.5,
      "HighVolatilityMultiplier": 1.8,
      "ExtremeVolatilityMultiplier": 3.0,

      "RequireVolumeSpikeForBreakout": false,
      "BreakoutLookback": 10,
      "VolumeSpikeMultiplier": 1.1,

      "NormalizeAtr": true,

      "SymbolSensitivity": {
        "BTCUSDT": 0.8,
        "ETHUSDT": 0.8,
        "BNBUSDT": 0.8,
        "DOGEUSDT": 1.2
      }
    },
    //we need this to keep
    //"TrendState": {
    //  "MinTrendStrengthPercent": 0.001,
    //  "StrongTrendStrengthPercent": 0.003,
    //  "MinSlopePercent": 0.0005,
    //  "LowVolatilityRangePercentThreshold": 0.0008,
    //  "MinRangeCandlesForVolatilityCheck": 10
    //},
    "TrendState": {
      "MinTrendStrengthPercent": 0.000001,
      "StrongTrendStrengthPercent": 0.00001,
      "MinSlopePercent": 0.000001,
      "LowVolatilityRangePercentThreshold": 0.00001,
      "MinRangeCandlesForVolatilityCheck": 5
    },

    "Candles": {
      "Interval": "1m",
      "SafetyBuffer": 20,
      "RefreshLimit": 2,
      "BackfillPadding": 5,
      "MaxBufferSize": 300
    }
  },

  "ExecutionSettings": {
    "Enabled": false,
    "UseMarketOrders": true,
    "Retry": {
      "Count": 2,
      "BaseDelayMs": 500
    }
  },

  "Trading": {
    "Mode": "Spot",
    "AllowAddToPosition": false,
    "MaxOpenPositionsPerSymbol": 1,
    "UseFeeGuard": true,
    "FeeRatePercent": 0.1,
    "EstimatedSpreadPercent": 0.05,
    "MinExpectedMovePercent": 0.3,
    "MinNetProfitPercent": 0.15,
    "CooldownSeconds": 30,
    "ReconciliationQuantityTolerance": 0.00000001,
    "ReconciliationIntervalMinutes": 10,
    "ReconciliationSnapshotMaxAgeSeconds": 180
  },

  "TradingDefaults": {
    "Symbol": "BNBUSDT",
    "Quantity": 0.01
  },

  "TradeMonitoring": {
    "IntervalSeconds": 5,
    "MaxTradeDurationMinutes": 10,

    "CloseOrderMaxRetries": 3,
    "CloseOrderRetryDelayMs": 1000,

    "FeeRate": 0.001,

    "EnableTimeExit": true,
    "EnableStopLossExit": true,
    "EnableTakeProfitExit": true,

    "EnableTrailingStop": false,
    "TrailingStopPercent": 0.5,

    "EnableBreakEvenStop": false,
    "BreakEvenTriggerPercent": 0.5,

    "CloseIdempotencyWindowSeconds": 60,

    "DefaultStopLossPercent": 0.4,
    "DefaultTakeProfitPercent": 0.6
  },

  "TradeAnalytics": {
    "Enabled": true,
    "IntervalMinutes": 5
  },

  "RiskSettings": {
    "MaxPositionQuote": 100,
    "MaxOrderQuote": 25,
    "MaxExposurePercent": 80,

    "MinOrderQuote": 5.0,
    "ReducedPositionMultiplier": 0.5,

    "EnableDailyLossLimit": true,
    "MaxDailyLossQuote": 20.0,

    "MaxOpenPositions": 1,
    "AllowShortSelling": true,

    "MinimumRiskScore": 25,

    "MaxPositionSize": 1.0,
    "MaxLeverage": 1.0,
    "QuoteAsset": "USDT",

    "DefaultStopLossPercent": 0.4,
    "DefaultTakeProfitPercent": 0.6
  },

  "OrderSync": {
    "Enabled": true,
    "IntervalSeconds": 20,
    "RetryDelaySeconds": 10,
    "BatchSize": 50,
    "RecvWindow": 30000,
    "PerOrderTimeoutSeconds": 10,
    "DelayBetweenRequestsMs": 100
  },

  "TradeSync": {
    "Enabled": true,
    "IntervalSeconds": 30,
    "RetryDelaySeconds": 10,
    "MaxSyncRetryCount": 5,
    "BatchSize": 50,
    "RecvWindow": 30000,
    "PerOrderTimeoutSeconds": 10,
    "DelayBetweenRequestsMs": 100
  },

  "PositionWorker": {
    "Enabled": true,
    "IntervalSeconds": 30,
    "RetryDelaySeconds": 10,
    "BatchSize": 50,
    "MaxRetryCount": 5
  },

  "BinanceRateLimit": {
    "MaxRequestsPerSecond": 10
  },
  "MarketData": {
    "MaxConcurrency": 3
  },

  "Workers": {
    "MarketData": {
      "IntervalSeconds": 5
    },
    "OrderSync": {
      "IntervalSeconds": 20
    },
    "TradeSync": {
      "IntervalSeconds": 30,
      "BatchSize": 50,
      "MaxSyncRetryCount": 5
    },
    "Position": {
      "IntervalSeconds": 30,
      "BatchSize": 50
    },
    "BalanceSync": {
      "IntervalSeconds": 60
    },
    "TimeSync": {
      "IntervalSeconds": 60
    }
  }
}