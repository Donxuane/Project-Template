{
  //"_comment": "Platform/exchange integration settings. This file overrides same keys from appsettings.json.",
  //"_comment_BaseURL": "Binance API base URL. Use testnet URL for safe testing, mainnet URL for production.",
  "BaseURL": "https://testnet.binance.vision",
  //"_comment_ApiKey": "Exchange API key used for authenticated endpoints. Prefer environment variables in real deployments.",
  "ApiKey": "",
  //"_comment_SecretKey": "Exchange API secret paired with ApiKey. Keep private; rotate if exposed.",
  "SecretKey": "",
  "PriceValidators": {
    //"_comment": "Exchange filter examples used by order validation logic (tick size, lot size, min notional).",
    "PRICE_FILTER": {
      "minPrice": "0.00000100",
      "maxPrice": "100000.00000000",
      "tickSize": "0.00000100"
    },
    "LOT_SIZE": {
      "minQty": "0.00100000",
      "maxQty": "100000.00000000",
      "stepSize": "0.00100000"
    },
    "MIN_NOTIONAL": {
      "minNotional": "0.00100000",
      "applyToMarket": true,
      "avgPriceMins": 5
    }
  },

  "RateLimiterSettings": {
    // "_comment": "Reference limits from exchange metadata; mainly informational unless explicitly enforced.",
    "REQUEST_WEIGHT": {
      "interval": "MINUTE",
      "intervalNum": 1,
      "limit": 6000
    },
    "ORDERS": {
      "interval": "SECOND",
      "intervalNum": 1,
      "limit": 10
    },
    "RAW_REQUESTS": {
      "interval": "MINUTE",
      "intervalNum": 5,
      "limit": 61000
    }
  },
  "Binance": {
    "Http": {
      "TimeoutSeconds": 15,
      "RetryCount": 3,
      "RetryBaseDelayMilliseconds": 300
    }
  },
  "GeneralApis": {
    // "_comment": "Endpoint definitions consumed by BinanceEndpointService for general Binance APIs.",
    "TestConnectivity": {
      "api": "/api/v3/ping",
      "type": "GET",
      "request": "none",
      "response": "none"
    },
    "CheckServerTime": {
      "api": "/api/v3/time",
      "type": "GET",
      "request": "none",
      "response": "ServerTimeResponse"
    },
    "ExchangeInformation": {
      "api": "/api/v3/exchangeInfo",
      "type": "GET",
      "request": "CurrencyPairs/none",
      "response": "ExchangeInfoResponse"
    }
  },
  "MarketData": {
    //"_comment": "Endpoint definitions for market data operations.",
    "MaxConcurrency": 3,
    "OrderBookDepth": {
      "api": "/api/v3/depth",
      "type": "GET",
      "request": "DepthRequest",
      "response": "DepthResponse"
    },
    "RecentTrades": {
      "api": "/api/v3/trades",
      "type": "GET",
      "request": "RecentTradesRequest",
      "response": "Trade"
    },
    "OldTradeLookUp": {
      "api": "/api/v3/historicalTrades",
      "type": "GET",
      "request": "HistoricalTradesRequest",
      "response": "Trade"
    },
    "AgregateTrades": {
      "api": "/api/v3/aggTrades",
      "type": "GET",
      "request": "AggregateTradesRequest",
      "response": "AggregateTrade"
    },
    "CandlestickDataKline": {
      "api": "/api/v3/klines",
      "type": "GET",
      "request": "KlineRequest",
      "response": "Kline"
    },
    "CurrentAveragePrice": {
      "api": "/api/v3/avgPrice",
      "type": "GET",
      "request": "AvgPriceRequest",
      "response": "AvgPriceResponse"
    },
    "_24hrTickerPriceChangeStats": {
      "api": "/api/v3/ticker/24hr",
      "type": "GET",
      "request": "Ticker24hrRequest",
      "response": "Ticker24hrFull/Mini"
    },
    "SymbolPriceTicker": {
      "api": "/api/v3/ticker/price",
      "type": "GET",
      "request": "SymbolPriceTickerRequest",
      "response": "SymbolPriceTickerResponse"
    },
    "SymbolOrderBookTicker": {
      "api": "/api/v3/ticker/bookTicker",
      "type": "GET",
      "request": "BookTickerRequest",
      "response": "BookTickerResponse"
    },
    "RollingWindowTicker": {
      "api": "/api/v3/ticker",
      "type": "GET",
      "request": "RollingTickerRequest",
      "response": "RollingTickerFull/Mini"
    }
  },
  "Trading": {
    //"_comment": "Endpoint definitions for order placement and order management. CooldownSeconds is used by DecisionWorker pre-execution guard.",
    //"_comment_Mode": "Trading mode used by DecisionEngine mapping (Spot or Futures). Spot keeps SELL as close/reduce-long intent.",
    "Mode": "Spot",
    //"_comment_AllowAddToPosition": "When false in Spot mode, BUY is blocked if an open long position already exists for symbol.",
    "AllowAddToPosition": false,
    //"_comment_MaxOpenPositionsPerSymbol": "Maximum number of simultaneous open positions per symbol; current spot pipeline effectively supports one.",
    "MaxOpenPositionsPerSymbol": 1,
    //"_comment_UseFeeGuard": "If true, decision-based entries are blocked when expected net profit after fees/spread is too small.",
    "UseFeeGuard": true,
    //"_comment_FeeRatePercent": "Estimated trading fee per side in percent (e.g., 0.1 means 0.1%).",
    "FeeRatePercent": 0.1,
    //"_comment_EstimatedSpreadPercent": "Estimated spread/slippage cost in percent for profitability checks.",
    "EstimatedSpreadPercent": 0.05,
    //"_comment_MinExpectedMovePercent": "Minimum gross expected move percent required before allowing a decision-based trade.",
    "MinExpectedMovePercent": 0.3,
    //"_comment_MinNetProfitPercent": "Minimum expected net profit percent (after fees/spread) required before execution.",
    "MinNetProfitPercent": 0.15,
    //"_comment_CooldownSeconds": "Per-symbol cooldown after successful execution; prevents opening another trade too soon.",
    "CooldownSeconds": 60,
    //"_comment_ReconciliationQuantityTolerance": "Absolute tolerance for local position vs exchange free+locked quantity reconciliation.",
    "ReconciliationQuantityTolerance": 0.00000001,
    //"_comment_ReconciliationIntervalMinutes": "Reconciliation worker run interval in minutes.",
    "ReconciliationIntervalMinutes": 10,
    //"_comment_ReconciliationSnapshotMaxAgeSeconds": "Maximum allowed age for latest balance snapshot before marked stale.",
    "ReconciliationSnapshotMaxAgeSeconds": 180,
    "NewOrder": {
      "api": "/api/v3/order",
      "type": "POST",
      "request": "NewOrderRequest",
      "response": "OrderResponse"
    },
    "QueryOrder": {
      "api": "/api/v3/order",
      "type": "GET",
      "request": "QueryOrderRequest",
      "response": "OrderResponse"
    },
    "QueryOpenOrders": {
      "api": "/api/v3/openOrders",
      "type": "GET",
      "request": "TradingSymbol",
      "response": "object"
    },
    "CancelOrder": {
      "api": "/api/v3/order",
      "type": "DELETE",
      "request": "CancelOrderRequest",
      "response": "OrderResponse"
    },
    "CancelAllOrders": {
      "api": "/api/v3/openOrders",
      "type": "DELETE",
      "request": "CancelAllOrdersRequest",
      "response": "OrderResponse"
    },
    "CancelReplaceOrder": {
      "api": "/api/v3/order/cancelReplace",
      "type": "POST",
      "request": "CancelReplaceOrderRequest",
      "response": "CancelReplaceResponse"
    },
    "OrderAmendKeepPriority": {
      "api": "/api/v3/order/amend/keepPriority",
      "type": "PUT",
      "request": "AmendOrderRequest",
      "response": "AmendOrderResponse"
    },
    "NewOrderList_OCO": {
      "api": "/api/v3/orderList/oco",
      "type": "POST",
      "request": "OcoOrderRequest",
      "response": "OrderListResponse"
    },
    "CancelOrderList": {
      "api": "/api/v3/orderList",
      "type": "POST",
      "request": "CancelOrderListRequest",
      "response": "OrderListResponse"
    },
    "NewOrderList_OTO": {
      "api": "/api/v3/orderList/oto",
      "type": "POST",
      "request": "OtoOrderRequest",
      "response": "OrderListResponse"
    },
    "NewOrderList_OTOCO": {
      "api": "/api/v3/orderList/otoco",
      "type": "POST",
      "request": "OtocoOrderRequest",
      "response": "OrderListResponse"
    }
  },
  "Account": {
    //"_comment": "Endpoint definitions for account, balances, and trade history.",
    "AccoutnInformation": {
      "api": "/api/v3/account",
      "type": "GET",
      "request": "AccountInfoRequest",
      "response": "AccountInfoResponse"
    },
    "OpenOrders": {
      "api": "/api/v3/openOrders",
      "type": "GET",
      "request": "OpenOrdersRequest",
      "response": "OrderResponse"
    },
    "Trades": {
      "api": "/api/v3/myTrades",
      "type": "GET",
      "request": "TradesRequest",
      "response": "TradeResponse"
    },
    "RateLimitOrderCount": {
      "api": "/api/v3/rateLimit/order",
      "type": "GET",
      "request": "",
      "response": "RateLimitResponse"
    },
    "PreventMatches": {
      "api": "/api/v3/myPreventedMatches",
      "type": "GET",
      "request": "",
      "response": "PreventedMatchResponse"
    },
    "Allocations": {
      "api": "/api/v3/myPreventedMatches",
      "type": "GET",
      "request": "",
      "response": "AllocationResponse"
    },
    "CommissionsRate": {
      "api": "/api/v3/account/commission",
      "type": "GET",
      "request": "",
      "response": "CommissionResponse"
    },
    "OrderAmendments": {
      "api": "/api/v3/order/amendments",
      "type": "GET",
      "request": "",
      "response": "OrderAmendmentResponse"
    }
  },
  "RiskSettings": {
    //"_comment": "Platform-level risk overrides. If values differ from appsettings.json, these win.",
    //"_comment_MaxPositionQuote": "Hard cap for position value in quote currency after trade (e.g. max 10,000 USDT per symbol).",
    "MaxPositionQuote": 10000,
    //"_comment_MaxOrderQuote": "Hard cap for single order notional in quote currency.",
    "MaxOrderQuote": 5000,
    //"_comment_MaxExposurePercent": "Maximum percentage of available quote equity that one symbol exposure may consume.",
    "MaxExposurePercent": 50,
    //"_comment_MaxPositionSize": "Maximum base-asset quantity allowed per symbol position (e.g. max BTC amount).",
    "MaxPositionSize": 1.0,
    //"_comment_MaxLeverage": "Simulated leverage limit for spot safety checks. 1.0 means no leverage-like overexposure.",
    "MaxLeverage": 1.0,
    //"_comment_QuoteAsset": "Quote currency used for valuation and balance checks (usually USDT).",
    "QuoteAsset": "USDT",
    //"_comment_DefaultStopLossPercent": "Default stop-loss distance from entry, in percent, used to compute StopLossPrice.",
    "DefaultStopLossPercent": 1.0,
    //"_comment_DefaultTakeProfitPercent": "Default take-profit distance from entry, in percent, used to compute TakeProfitPrice.",
    "DefaultTakeProfitPercent": 2.0
  },
  "DecisionEngine": {
    "MinConfidence": 0.70,
    "Strategies": {
      "MovingAverageCrossover": {
        "MinConfidence": 0.70
      }
    }
  }

}
